# ============================================================
# Production env file template for AWS deployment.
# Copy to .env.prod and fill real values:
#   cp .env.prod.example .env.prod
# Then run:
#   docker compose --env-file .env.prod \
#     -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# .env.prod is gitignored — NEVER commit real secrets.
# ============================================================

# ============================================================
# AWS / Image registry
# ============================================================
GITHUB_OWNER=your-github-username
IMAGE_TAG=latest

# Set after running Phase 10 Task 10.5 (Elastic IP allocate)
# Use dashed form for nip.io subdomain (e.g. 1-2-3-4 for IP 1.2.3.4)
ELASTIC_IP=__SET_AFTER_EC2_LAUNCH__
ELASTIC_IP_DASHED=__SET_AFTER_EC2_LAUNCH__

# ============================================================
# CORS — origins allowed by API Gateway
# Multiple origins comma-separated, no spaces.
# ============================================================
CORS_ALLOWED_ORIGINS=https://app.__ELASTIC_IP_DASHED__.nip.io,http://localhost:3000

# ============================================================
# PostgreSQL (shared by all business services + per-DB schema)
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__CHANGE_ME_STRONG_PASSWORD__

# ============================================================
# Keycloak DB
# ============================================================
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=__CHANGE_ME_STRONG_PASSWORD__

# ============================================================
# Keycloak server
# KC_HOSTNAME PHẢI là URL đầy đủ (có https://) để Keycloak đóng dấu issuer cố định:
#   iss = https://auth.<ip>.nip.io/realms/ecommerce
# Nếu chỉ để hostname trần (auth.<ip>.nip.io) -> token cấp nội bộ có
#   iss = http://auth.<ip>.nip.io:8080/... -> api-gateway từ chối (401 "iss not valid").
# ============================================================
KC_HOSTNAME=https://auth.__ELASTIC_IP_DASHED__.nip.io
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=__CHANGE_ME_STRONG_PASSWORD__

# Gateway validate JWT: issuer-uri PHẢI khớp `iss` của token (= KC_HOSTNAME + /realms/ecommerce).
# jwk-set-uri trỏ nội bộ (lấy public key qua Docker network).
KEYCLOAK_ISSUER_URI=https://auth.__ELASTIC_IP_DASHED__.nip.io/realms/ecommerce
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/ecommerce/protocol/openid-connect/certs

# Keycloak realm client credentials (must match realm export)
KEYCLOAK_CLIENT_ID=ecommerce-client
KEYCLOAK_CLIENT_SECRET=__CHANGE_ME_FROM_REALM_EXPORT__

# Keycloak admin service account
KEYCLOAK_ADMIN_CLIENT_ID=identity-service-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=__CHANGE_ME_FROM_REALM_EXPORT__

# ============================================================
# Eureka discovery
# ============================================================
EUREKA_USER=eureka
EUREKA_PASSWORD=__CHANGE_ME_STRONG_PASSWORD__
EUREKA_DEFAULT_ZONE=http://eureka:__CHANGE_ME_STRONG_PASSWORD__@discovery-server:8761/eureka/

# ============================================================
# Grafana
# ============================================================
GF_SECURITY_ADMIN_PASSWORD=__CHANGE_ME_STRONG_PASSWORD__

# ============================================================
# VNPAY sandbox (paste TmnCode + HashSecret tu VNPAY merchant portal)
# Return + IPN URLs phai la HTTPS public (qua Caddy).
# Trong VNPAY merchant portal, khai bao:
#   - Return URL: https://api.<ip-dashed>.nip.io/api/payments/vnpay/return
#   - IPN URL   : https://api.<ip-dashed>.nip.io/api/payments/vnpay/ipn
# IPN la nguon su that quyet dinh don hang CONFIRMED, bat buoc phai khai bao.
# ============================================================
VNPAY_TMN_CODE=__YOUR_VNPAY_TMN_CODE__
VNPAY_HASH_SECRET=__YOUR_VNPAY_HASH_SECRET__
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://api.__ELASTIC_IP_DASHED__.nip.io/api/payments/vnpay/return

# Frontend redirect target sau khi VNPAY callback xu ly xong.
# Phai tro toi route /order/result (KHONG phai /orders) — trang nay doc
# orderId + status roi forward sang /orders/{id} de hien ket qua.
FRONTEND_ORDER_RESULT_URL=https://app.__ELASTIC_IP_DASHED__.nip.io/order/result

# ============================================================
# SMTP (Mailpit dev mode — for thesis demo, no real email)
# ============================================================
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false
SMTP_FROM=no-reply@ecommerce.local

# ============================================================
# Frontend (Next.js public env vars baked at build time)
# Server-side API_BASE_URL points to Docker internal DNS
# ============================================================
NEXT_PUBLIC_API_BASE_URL=https://api.__ELASTIC_IP_DASHED__.nip.io
NEXT_PUBLIC_APP_URL=https://app.__ELASTIC_IP_DASHED__.nip.io
