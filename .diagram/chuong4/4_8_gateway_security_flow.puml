@startuml
title Hình 4.8 - Luồng xác thực và phân quyền qua API Gateway

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam roundcorner 8
skinparam ArrowColor #475569
skinparam ArrowThickness 1.3
skinparam ParticipantBorderColor #475569
skinparam ParticipantBackgroundColor #F1F5F9
skinparam NoteBorderColor #F97316
skinparam NoteBackgroundColor #FFF7ED

actor "User / Admin" as User
participant "Storefront /\nAdmin Panel" as Client #E0F2FE
participant "Keycloak" as Keycloak #FEF3C7
participant "API Gateway" as Gateway #DCFCE7
database "Redis\nToken Bucket" as Redis #FCE7F3
participant "Backend Service\ninternal network" as Backend #BBF7D0

User -> Client : Login
Client -> Keycloak : Credentials / Authorization flow
Keycloak --> Client : Access Token JWT\nroles, email, subject

Client -> Gateway : API request\nAuthorization: Bearer JWT
Gateway -> Keycloak : JWKS public key\n(cache after first load)
Gateway -> Gateway : Verify signature,\nissuer, expiry, claims

alt token invalid
  Gateway --> Client : 401 Unauthorized
else token valid
  Gateway -> Gateway : Check route authorization\nROLE_USER / ROLE_ADMIN / public
  alt role forbidden
    Gateway --> Client : 403 Forbidden
  else route allowed
    Gateway -> Redis : Consume token bucket\norder: 10 req/s\nflash sale: 3 req/s
    alt rate limit exceeded
      Gateway --> Client : 429 Too Many Requests
    else accepted
      Gateway -> Backend : Forward request\nX-User-Id\nX-User-Roles\nX-User-Email
      Backend -> Backend : Trust Gateway headers
      Backend --> Gateway : Business response
      Gateway --> Client : Response
    end
  end
end

note over Backend
  Backend không expose ra ngoài Docker network.
  Chỉ Gateway được gọi trực tiếp service nội bộ.
end note

@enduml
