@startuml
title Hình 4.2 - Sơ đồ thành phần bốn tầng của hệ thống

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam roundcorner 8
skinparam packageStyle rectangle
skinparam ArrowColor #475569
skinparam ArrowThickness 1.3
skinparam PackageBorderColor #334155
skinparam PackageBackgroundColor #F8FAFC
skinparam ComponentBorderColor #475569
skinparam ComponentBackgroundColor #E0F2FE
skinparam DatabaseBorderColor #475569
skinparam DatabaseBackgroundColor #DCFCE7
skinparam QueueBorderColor #475569
skinparam QueueBackgroundColor #FEF3C7

top to bottom direction

package "Client Layer" as ClientLayer #EFF6FF {
  component "Web Browser\nStorefront" as Browser
  component "Admin Panel" as AdminPanel
  component "Postman / k6" as ApiTools
}

package "Edge & Spring Cloud Layer" as EdgeLayer #ECFDF5 {
  component "API Gateway\nSpring Cloud Gateway" as Gateway
  component "Eureka Server\nService Registry" as Eureka
  component "Config Server\nSpring Cloud Config" as Config
  component "Keycloak\nIdentity Provider" as Keycloak
}

package "Business Services Layer\n13 independent bounded contexts" as BusinessLayer #F8FAFC {
  component "identity-service" as Identity
  component "user-service" as User
  component "product-service" as Product
  component "inventory-service" as Inventory
  component "cart-service" as Cart
  component "order-service\nSaga Orchestrator" as Order
  component "payment-service" as Payment
  component "voucher-service" as Voucher
  component "notification-service" as Notification
  component "review-service" as Review
  component "search-service" as Search
  component "content-service" as Content
  component "flash-sale-service" as FlashSale
}

package "Infrastructure Layer" as InfraLayer #FFF7ED {
  database "PostgreSQL\nlogical DB per service" as Postgres
  database "Redis\ncart, cache, rate limit,\nflash sale atomic keys" as Redis
  queue "Kafka KRaft\nasync event bus" as Kafka
  database "Elasticsearch\nproduct search index" as Elasticsearch
  component "Mailpit / SMTP" as Mail
  component "Prometheus" as Prometheus
  component "Grafana" as Grafana
  component "Zipkin" as Zipkin
}

Browser --> Gateway : HTTPS REST
AdminPanel --> Gateway : HTTPS REST
ApiTools --> Gateway : test / load

Gateway --> Keycloak : JWT / JWKS
Gateway --> Eureka : service lookup
Gateway --> BusinessLayer : route lb://service

BusinessLayer --> Config : fetch centralized config
BusinessLayer --> Eureka : register / heartbeat
BusinessLayer --> BusinessLayer : REST / OpenFeign
BusinessLayer --> Kafka : publish / consume events
BusinessLayer --> Postgres : own database only
Cart --> Redis : cart keys
Product --> Redis : product cache
Gateway --> Redis : token bucket
FlashSale --> Redis : Lua atomic stock
Search --> Elasticsearch : read model
Notification --> Mail : email delivery
BusinessLayer --> Prometheus : metrics endpoint
BusinessLayer --> Zipkin : traces
Prometheus --> Grafana : dashboard data

note bottom
  Nguyên tắc chính: Client chỉ đi qua Gateway; service sở hữu dữ liệu của mình;
  giao tiếp chéo dùng REST/OpenFeign hoặc Kafka, không truy cập DB trực tiếp.
end note

@enduml
