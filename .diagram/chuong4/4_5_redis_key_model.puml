@startuml
title Hình 4.5 - Mô hình khóa Redis: Cart, Cache, Flash Sale

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam roundcorner 8
skinparam ArrowColor #475569
skinparam ArrowThickness 1.3
skinparam RectangleBorderColor #475569
skinparam RectangleBackgroundColor #F8FAFC
skinparam DatabaseBorderColor #475569
skinparam DatabaseBackgroundColor #DCFCE7
skinparam NoteBorderColor #F97316
skinparam NoteBackgroundColor #FFF7ED

left to right direction

database "Redis 8" as Redis

rectangle "Cart Keys\ncart:{userId}\ncart:{sessionId}" as CartKeys #DBEAFE {
  rectangle "Type: Hash" as CartType
  rectangle "Value: productId -> quantity/options" as CartValue
  rectangle "TTL: 7 ngày user\n24 giờ guest" as CartTtl
}

rectangle "Product Cache\nproduct:{productId}" as ProductKeys #ECFDF5 {
  rectangle "Type: String JSON" as ProductType
  rectangle "Value: product detail snapshot" as ProductValue
  rectangle "TTL: 30 phút" as ProductTtl
  rectangle "Invalidate khi product updated" as ProductInvalidation
}

rectangle "Flash Sale Keys\nflash-sale:{campaignId}:stock\nflash-sale:{campaignId}:buyers" as FlashSaleKeys #FEF3C7 {
  rectangle "stock: Integer slot còn lại" as StockKey
  rectangle "buyers: Set userId đã mua" as BuyersKey
  rectangle "TTL: đến thời điểm kết thúc campaign" as FlashTtl
  rectangle "Lua script: check buyer + decrement stock atomic" as Lua
}

rectangle "API Gateway Rate Limit\nrequest_rate_limiter.{route}.{principal}" as RateLimitKeys #FCE7F3 {
  rectangle "Token bucket state" as TokenBucket
  rectangle "Dùng cho order và flash sale endpoints" as SensitiveRoutes
}

Redis --> CartKeys
Redis --> ProductKeys
Redis --> FlashSaleKeys
Redis --> RateLimitKeys

note bottom
  Redis được tách theo mục đích: dữ liệu giỏ hàng có TTL,
  cache sản phẩm đọc nhiều, flash sale cần atomic operation,
  và rate limiting bảo vệ endpoint nhạy cảm.
end note

@enduml
