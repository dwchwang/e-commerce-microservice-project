@startuml
title Hình 5.2 - Spring Cloud layer: Gateway, Discovery Server và Config Server

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam roundcorner 8
skinparam ArrowColor #475569
skinparam ArrowThickness 1.3
skinparam ComponentBorderColor #475569
skinparam ComponentBackgroundColor #F8FAFC
skinparam DatabaseBorderColor #475569
skinparam DatabaseBackgroundColor #DCFCE7

left to right direction

component "Client\nStorefront / Admin / k6" as Client #E0F2FE
component "api-gateway\nSpring Cloud Gateway\n:8080" as Gateway #DCFCE7
component "discovery-server\nNetflix Eureka\n:8761" as Eureka #FEF3C7
component "config-server\nSpring Cloud Config\nnative profile" as Config #FEF3C7
database "Redis\nrate limiter" as Redis #FCE7F3
component "Keycloak\nJWKS / OIDC" as Keycloak #FEF3C7

package "Business services" as Services #F8FAFC {
  component "product-service" as Product
  component "order-service" as Order
  component "payment-service" as Payment
  component "flash-sale-service" as FlashSale
  component "... other services" as Others
}

Client --> Gateway : HTTPS/HTTP REST
Gateway --> Keycloak : verify JWT\nJWKS cache
Gateway --> Redis : token bucket
Gateway --> Eureka : lookup lb://service-name
Gateway --> Product : route /api/products/**
Gateway --> Order : route /api/orders/**
Gateway --> Payment : route /api/payments/**
Gateway --> FlashSale : route /api/flash-sales/**

Product --> Eureka : register + heartbeat
Order --> Eureka : register + heartbeat
Payment --> Eureka : register + heartbeat
FlashSale --> Eureka : register + heartbeat
Others --> Eureka : register + heartbeat

Product --> Config : fetch product-service-{profile}.yml
Order --> Config : fetch order-service-{profile}.yml
Payment --> Config : fetch payment-service-{profile}.yml
FlashSale --> Config : fetch flash-sale-service-{profile}.yml
Gateway --> Config : fetch gateway routes/security config

note bottom
  Gateway là điểm vào duy nhất. Eureka loại bỏ hard-code địa chỉ service.
  Config Server chuẩn hóa cấu hình theo service và profile khi khởi động.
end note

@enduml
