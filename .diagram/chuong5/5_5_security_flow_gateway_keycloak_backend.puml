@startuml
title Hình 5.5 - Security flow: Client, Gateway, Keycloak và backend service

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam roundcorner 8
skinparam ArrowColor #475569
skinparam ArrowThickness 1.3
skinparam ParticipantBorderColor #475569
skinparam ParticipantBackgroundColor #F1F5F9
skinparam DatabaseBorderColor #475569
skinparam DatabaseBackgroundColor #DCFCE7

actor "User / Admin" as User
participant "Next.js Client\nhttpOnly cookie" as Client #E0F2FE
participant "Keycloak" as Keycloak #FEF3C7
participant "API Gateway\nSecurityConfig + filters" as Gateway #DCFCE7
database "Redis\nrate limiter" as Redis #FCE7F3
participant "Backend Service\ninternal Docker network" as Backend #BBF7D0

User -> Client : login
Client -> Keycloak : authenticate
Keycloak --> Client : access token JWT\nRS256

Client -> Gateway : request\nAuthorization: Bearer token
Gateway -> Keycloak : load JWKS public key\ncached
Gateway -> Gateway : validate signature,\nexpiry, claims
Gateway -> Gateway : match path/method\npublic/auth/admin policy

alt invalid token
  Gateway --> Client : 401
else missing role
  Gateway --> Client : 403
else allowed
  Gateway -> Redis : apply token bucket\norders / flash-sale
  alt throttled
    Gateway --> Client : 429
  else accepted
    Gateway -> Backend : forward with trusted headers\nX-User-Id\nX-User-Email\nX-User-Roles
    Backend -> Backend : use trusted headers\nno JWT re-validation
    Backend --> Gateway : business response
    Gateway --> Client : response
  end
end

@enduml
