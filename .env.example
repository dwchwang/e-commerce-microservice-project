# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# ============================================================
# Keycloak DB
# ============================================================
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me

# ============================================================
# Keycloak
# ============================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# Keycloak client credentials (must match realm export)
KEYCLOAK_CLIENT_ID=ecommerce-client
KEYCLOAK_CLIENT_SECRET=change-me

# Keycloak admin service account (must match realm export)
KEYCLOAK_ADMIN_CLIENT_ID=identity-service-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me

# ============================================================
# Eureka
# ============================================================
EUREKA_USER=eureka
EUREKA_PASSWORD=change-me
EUREKA_DEFAULT_ZONE=http://eureka:change-me@discovery-server:8761/eureka/

# ============================================================
# Grafana
# ============================================================
GF_SECURITY_ADMIN_PASSWORD=change-me

# ============================================================
# Phase 6 Payment + Notification
# ============================================================
PAYMENT_DB_URL=jdbc:postgresql://postgres:5432/payment_db
NOTIFICATION_DB_URL=jdbc:postgresql://postgres:5432/notification_db
VNPAY_TMN_CODE=change-me
VNPAY_HASH_SECRET=change-me
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8080/api/payments/vnpay/return
FRONTEND_ORDER_RESULT_URL=http://localhost:3000/order/result
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false
